<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/colorSurface">

    <!-- Заголовок диалога (без AlertDialog-хрома) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="8dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/history_answer_title"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/colorOnBackground" />

        <!-- Кнопка озвучки (говорящий человек) -->
        <ImageButton
            android:id="@+id/btnDialogTts"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_voice_person"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="@string/menu_tts" />

        <!-- Закрыть -->
        <ImageButton
            android:id="@+id/btnDialogClose"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="center"
            android:contentDescription="@string/back" />

    </LinearLayout>

    <!-- Разделитель -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/colorInputBg" />

    <!-- Вопрос пользователя -->
    <TextView
        android:id="@+id/tvDialogQuestion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="@color/colorTextSecondary"
        android:textStyle="italic"
        android:maxLines="3"
        android:ellipsize="end"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp" />

    <!-- Разделитель -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/colorInputBg" />

    <!-- Прокручиваемый ответ ИИ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="400dp">

        <TextView
            android:id="@+id/tvDialogAnswer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="@color/colorOnBackground"
            android:lineSpacingMultiplier="1.5"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="12dp"
            android:paddingBottom="16dp"
            android:textIsSelectable="true" />

    </ScrollView>

</LinearLayout>
